root = true

[*]
charset = utf-8

[{CMakeLists.txt,*.cmake}]
trim_trailing_whitespace = true
insert_final_newline = true
indent_size = 2
indent_style = space

[*.{c,h,cpp,hpp,mm}]
trim_trailing_whitespace = true
indent_size = 2
indent_style = space

[Classes/**/*.{cpp,hpp,mm,h,c}]
trim_trailing_whitespace = false
indent_size = 4
indent_style = tab
